generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL") // Vercel Postgres env var
  directUrl = env("POSTGRES_URL_NON_POOLING") // Vercel Postgres direct url
}

model Product {
  id              String   @id @default(cuid())
  name            String
  description     String?
  price           Float
  category        String
  images          String   @default("[]") // JSON string
  stock           Int      @default(0)
  colors          String   @default("[]") // JSON string of objects {hex, name}
  sizeTable       String   @default("[]") // JSON string
  isNewCollection Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      String   @default("CUSTOMER")
  name      String?
  createdAt DateTime @default(now())
  address   String?
  phone     String?
  province  String?
  transport String?
}

model Category {
  id   String @id @default(cuid())
  name String @unique
}

model Banner {
  id    String @id @default(cuid())
  image String
  title String?
}

model FAQ {
  id      String @id @default(cuid())
  title   String
  content String
}

model BrandConfig {
  id           String @id @default("singleton")
  description  String?
  address      String?
  phone        String?
  instagram    String?
  rating       String?
  reviewsCount String?
  hours        String?
}
